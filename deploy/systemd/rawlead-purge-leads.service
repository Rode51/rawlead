[Unit]
Description=RawLead purge old + delisted leads (7d retention + DELIST_PURGE_DAYS)
After=network-online.target

[Service]
Type=oneshot
User=rawlead
WorkingDirectory=/opt/rawlead
EnvironmentFile=/opt/rawlead/.env
ExecStart=/opt/rawlead/.venv/bin/python scripts/purge_old_leads.py --apply
Nice=10

[Install]
WantedBy=multi-user.target
