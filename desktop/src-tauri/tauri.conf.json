{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FL Radar",
  "version": "0.1.0",
  "identifier": "com.rode51.fl-radar-pult",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "FL Radar — пульт",
        "width": 400,
        "height": 560,
        "minWidth": 400,
        "maxWidth": 400,
        "minHeight": 560,
        "maxHeight": 760,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:18765 http://localhost:18765 ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
