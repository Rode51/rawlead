{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "rawlead-bg", "color": "#FFFFFF", "name": "Page" },
        { "slug": "rawlead-section", "color": "#F5F5F7", "name": "Section" },
        { "slug": "rawlead-inverse", "color": "#0A0A0A", "name": "Inverse" },
        { "slug": "rawlead-text", "color": "#0A0A0A", "name": "Text" },
        { "slug": "rawlead-body", "color": "#3D3D3D", "name": "Body" },
        { "slug": "rawlead-muted", "color": "#6B6B6B", "name": "Muted" },
        { "slug": "rawlead-border", "color": "#E8E8EC", "name": "Border" },
        { "slug": "rawlead-fl", "color": "#2563EB", "name": "FL.ru" },
        { "slug": "rawlead-kwork", "color": "#EA580C", "name": "Kwork" },
        { "slug": "rawlead-tg", "color": "#0EA5E9", "name": "Telegram" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Manrope\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "name": "Manrope",
          "slug": "manrope"
        },
        {
          "fontFamily": "\"Unbounded\", \"Manrope\", system-ui, sans-serif",
          "name": "Unbounded",
          "slug": "unbounded"
        }
      ]
    },
    "layout": {
      "contentSize": "1120px",
      "wideSize": "1120px"
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--manrope)"
    },
    "color": {
      "background": "#FFFFFF",
      "text": "#3D3D3D"
    }
  }
}
