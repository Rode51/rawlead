# P5-PREP / VPS: CORS — список origin через запятую (без *). Пусто = * (localhost)
# Локально: RADAR_CORS_ORIGINS=http://radarzakaz.local
# Прод VPS: RADAR_CORS_ORIGINS=https://rawlead.ru
# RADAR_CORS_ORIGINS=https://rawlead.ru
