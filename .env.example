# Шаблон. Реальные токены в Git не коммитить.
#
# --- Три файла (S-SPLIT) — не один .env на всё ---
# 1) `.env`           — SHARED: Telethon, DATABASE_URL, FL/Kwork, прокси, FH token
# 2) `.env.legacy`    — @FLPARSINGBOT, :18765, RADAR_EXCHANGES=0, FILTERS_LEGACY
# 3) `.env.site`      — @rawlead_bot, :18775, main+tg, FILTERS_SITE, TG_JOIN v2
# Загрузка: `.env.{profile}` (override) → `.env` (дозаполняет). См. docs/FOR_YOU.md
# Запуск: ярлыки site/legacy.vbs или `--profile legacy|site`.
# LEGACY: data/radar_legacy.log, пульт :18765, FILTERS_LEGACY.md, AI_MODE=legacy (один разбор).
# SITE:   data/radar_site.log,   пульт :18775, FILTERS_SITE.md,   AI_MODE=split (L1 лента + L2 бот).
# RADAR_PROFILE=legacy
# RADAR_CONTROL_PORT=18765
# RADAR_TG_ENABLED=0
# RADAR_EXCHANGES_ENABLED=0
# RADAR_LOG_PATH=data/radar_legacy.log
# FILTERS_MD_PATH=docs/ops/FILTERS_LEGACY.md
# AI_MODE=legacy
# Legacy ▶ — neon_legacy_consumer (читает Neon), не main.py
# LEGACY_NEON_POLL_SEC=60
#
# SITE (.env.site): TELEGRAM_BOT_TOKEN и AI_API_KEY (или OPENROUTER_API_KEY) — отдельные от legacy.
# RADAR_PROFILE=site
# RADAR_CONTROL_PORT=18775
# RADAR_TG_ENABLED=1
# RADAR_EXCHANGES_ENABLED=1
# RADAR_LOG_PATH=data/radar_site.log
# AI_MODE=split
# Site ▶ — main + tg_main (единственный парсер бирж → Neon + /lenta/)
# 0 (default) = Site не шлёт owner-пуши в Telegram (биржи/ТГ); 1 = dogfood owner в @rawlead_bot
# SITE_NOTIFY_OWNER=0

# Обязательные (см. docs/ops/SOURCES_POOLS.md). Лента заказов; радар сам ходит на page-2..3:
FL_PROJECTS_URL=https://www.fl.ru/projects/?kind=1

# Необязательно: лента заказов Kwork (пусто = только FL). См. docs/ops/SOURCES_POOLS.md
KWORK_PROJECTS_URL=https://kwork.ru/projects?c=all

# Интервал опроса в минутах (по ТЗ минимум 10; для ускорения тестов можно 2 — см. config MIN)
POLL_INTERVAL_MINUTES=10

# Страниц ленты FL за цикл (1–5, default 3). Меньше = быстрее цикл бирж.
# FL_LISTING_MAX_PAGES=2

# O60b: лимит on-demand draft/час на пользователя; 0 = без лимита (default)
# DRAFT_HOURLY_LIMIT=0
# O39 (опц., не реализовано — сейчас лимит = FL_LISTING_MAX_PAGES / полная лента Kwork):
# FL_FETCH_LIMIT=
# KWORK_FETCH_LIMIT=

# Telegram Bot API: токен бота и id чата (куда слать уведомления)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Login Widget на /cabinet/ (P4): тот же бот или отдельный
# TELEGRAM_LOGIN_BOT_TOKEN=
# В wp-config.php для виджета: define('RAWLEAD_TG_BOT_USERNAME', 'YourBotName');
# JWT кабинета (7 дней); пусто — берётся RAWLEAD_API_KEY
# RAWLEAD_JWT_SECRET=
# Твой user id (личный чат с @ботом) — НЕ id бота
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
# Необязательно: id бота getMe (напр. 8882739264) — не путать с TELEGRAM_CHAT_ID
TELEGRAM_BOT_USER_ID=

# Обязательно: прокси только для Bot API (парсеры FL — напрямую, без прокси).
# Формат: http://host:port:user:pass или http://user:pass@host:port
TG_PROXY_URL=http://host:port:user:pass

# Cursor IDE — см. FOR_YOU.md § Cursor
# CURSOR_PROXY_RELAY=1 — локальный 127.0.0.1:18777, автосмена upstream (рекомендуется)
# CURSOR_PROXY_RELAY_PORT=18777
# CURSOR_PROXY_POOL_URLS=http://host:port:user:pass,...  (US/NL/PT первыми, RU/BY в конце)
CURSOR_PROXY_ENABLED=1
CURSOR_PROXY_AUTO_FALLBACK=1
CURSOR_PROXY_DISABLE_IF_DEAD=1
# Если RELAY=0: CURSOR_PROXY_URL=... и CURSOR_PROXY_FALLBACK_URLS=...

# Необязательно: пути к SQLite и логу (относительно текущей папки при запуске)
SQLITE_PATH=data/projects.db
# VPS legacy (опц.): отдельный файл — пауза FLPARSING не трогает Site даже без миграции ключей
# SQLITE_PATH=data/projects_legacy.db
# Пауза по профилю (код): radar_paused_site / radar_paused_legacy (старый radar_paused — fallback)
RADAR_LOG_PATH=data/radar.log

# Необязательно: User-Agent для GET ленты FL.ru (пусто = значение по умолчанию в коде)
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; compatible; FLRadar/1.0)

# --- Этап 2: ИИ-разбор (docs/team/architect/AI.md, TZ §5). AI_ENABLED=0 → короткое MVP-сообщение ---
AI_ENABLED=0
AI_PROVIDER=openrouter
AI_API_KEY=
AI_MODEL=google/gemini-2.5-flash-lite
# F-LOCAL: L1 ingest — O72e-9 A/B winner 2026-06-02: google/gemini-2.5-flash-lite (89.5% heuristic)
OPENROUTER_MODEL_SUMMARY=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL_SUMMARY=qwen/qwen-3.5-flash-02-23  # A/B 0% — slug/API fail, не использовать
# OPENROUTER_MODEL_SUMMARY=mistralai/mistral-small-3.2-24b-instruct
# OPENROUTER_MODEL_SUMMARY=openai/gpt-4o-mini
# OPENROUTER_MODEL_SUMMARY=google/gemini-2.5-flash
# OPENROUTER_MODEL_PREMIUM=anthropic/claude-sonnet-4
# O57: один shared-отклик на lead — Sonnet (1×/lead)
# O72e-10: per-user uniquify (клик «Написать отклик») — premium, отдельно от shared L2
OPENROUTER_MODEL_L3_UNIQUIFY=google/gemini-2.5-flash
# OPENROUTER_MODEL_SHARED_DRAFT=anthropic/claude-sonnet-4
# O82-w2: F2+ совместимость (hybrid lead/user coverage)
# RANK_MATCH_LEAD_WEIGHT=0.65
# RANK_MATCH_USER_WEIGHT=0.35
# RANK_MATCH_USER_CAP=6
# Site radar: tools-only L2 backfill для visible leads без tools_required
# TOOLS_BACKLOG_DRAIN=1
# TOOLS_BATCH_PER_CYCLE=8
# O72c: LLM judge L1/L2 + рекомендации правок промптов (только аудит, не prod ingest)
# OPENROUTER_MODEL_JUDGE=anthropic/claude-sonnet-4
# Порог до вызова ИИ (пусто в коде = 1000). См. docs/ops/PROFILE.md
MIN_BUDGET_RUB=1000
# Лента /lenta/ (vision v0.10): порог «Брать» для design/marketing/text при фильтре ≥70
# AI_SCORE_MIN_DIGITAL=55
# AI_SCORE_MIN_DEV=70
# 0 = не слать в TG при вердикте «Пропустить»; 1 = слать всё равно
AI_NOTIFY_SKIP=0
# 1 = в ИИ почти все новые заказы (режет только стоп-слова); 0 = нужно слово из docs/ops/FILTERS.md «берём»
FILTER_WIDE=1

# --- Фаза 1: Telethon (мониторинг чатов). Код подключит Coder; секреты только в .env ---
# Взять на https://my.telegram.org/apps (один раз на проект)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Прокси ТОЛЬКО для мониторингового аккаунта (не домашний IP). Формат как TG_PROXY_URL:
TELETHON_PROXY_URL=http://host:port:user:pass
# Session+Json: путь к .session БЕЗ расширения (acc1, обратная совместимость)
TELETHON_SESSION_PATH=C:/path/to/+66953964608_telethon
# Три номера — отдельная сессия + прокси на каждый (см. docs/ops/SOURCES_POOLS.md)
TELETHON_SESSION_ACC1=C:/path/to/+66953964608_telethon
TELETHON_PROXY_ACC1=http://host:port:user:pass
TELETHON_SESSION_ACC2=C:/path/to/+66967716330_telethon
TELETHON_PROXY_ACC2=http://host:port:user:pass
TELETHON_SESSION_ACC3=C:/path/to/+66985780470_telethon
TELETHON_PROXY_ACC3=http://host:port:user:pass
# 1 = TCP-проверка прокси до connect (fail-closed); 0 = только строка в .env
TELETHON_PROXY_PROBE=1
TELETHON_PROXY_PROBE_TIMEOUT=8
TELETHON_PROXY_ALERT_COOLDOWN=300
# Id чатов для listen: путь к файлу (рекомендуется) или через запятую — после tg_list_dialogs.py
TELETHON_MONITOR_ACCOUNT=acc1
# Один tg_main слушает все перечисленные аккаунты (свой файл id на каждый)
TELETHON_MONITOR_ACCOUNTS=acc1,acc2,acc3
TELETHON_CHAT_IDS=data/telethon_chat_ids_acc1.txt
# Опционально явно: TELETHON_CHAT_IDS_ACC2=data/telethon_chat_ids_acc2.txt
# Ночь Asia/Irkutsk: 02:00–07:00 — длиннее пауза переподключения tg_main
NIGHT_TZ=Asia/Irkutsk
NIGHT_START=02:00
NIGHT_END=07:00
TG_RECONNECT_SEC=30
TG_RECONNECT_NIGHT_SEC=300
# Проверка +66: раз в N минут; повтор алерта в бот — не чаще M минут
HEALTH_CHECK_MINUTES=15
HEALTH_ALERT_COOLDOWN_MINUTES=60

# --- Очередь join (scripts/tg_join_queue.py). См. docs/ops/TG_JOIN_SCHEDULE.md ---
TG_JOIN_MAX_PER_HOUR=4
TG_JOIN_MIN_DELAY_SEC=900
TG_JOIN_MAX_DELAY_SEC=1200
TG_JOIN_MAX_PER_DAY=25
TG_JOIN_DAEMON_INTERVAL_SEC=3600
# join всех TELETHON_MONITOR_ACCOUNTS внутри tg_main (не отдельный процесс)
TG_JOIN_IN_TG_MAIN=1
# устарело: TG_JOIN_AUTO_ACC1 (читается, если TG_JOIN_IN_TG_MAIN не задан)
# устарело: TG_JOIN_DAEMON_ACCOUNTS — tg_join_daemon.py не в автозапуске
# TG_JOIN_STATE_PATH=data/tg_join_state.json
# TG_JOIN_LOG_PATH=data/tg_join.log
# legacy: docs/ops/TG_JOIN_QUEUE.csv
# site (Tier A PDF): docs/ops/TG_JOIN_QUEUE_v2.csv
# TG_JOIN_QUEUE_CSV=docs/ops/TG_JOIN_QUEUE_v2.csv

# --- Публичная лента /lenta/ (P1): только эти source в API, радар и skills/catalog ---
# Канон: docs/ops/PUBLIC_FEED_WEB_SOURCES.txt
# По умолчанию (пусто): fl,kwork
PUBLIC_FEED_SOURCES=fl,kwork
# O63: шесть бирж в ленту (w1+w2)
# PUBLIC_FEED_SOURCES=fl,kwork,youdo,freelance_ru,freelancejob,pchyol
# Вакансии (парсеры в src/, не вызывать без явного env):
# PUBLIC_FEED_SOURCES=fl,kwork,vc_ru,habr_career
# TG в ленту: python scripts/build_public_feed_sources.py → строка в .env
# Ключ Neon: tg:-1001199102856 (peer из tg_main), не голый chat_id из CSV

# VC.ru: канон — API jobs (без ключа)
# VC_RU_API_URL=https://api.vc.ru/v2.8/timeline?subsitesIds=jobs
# VC_RU_LISTING_URL=https://vc.ru/services

# Freelancehunt: HTML часто 403/Cloudflare — API с токеном (freelancehunt.com/my/api)
# FREELANCEHUNT_API_TOKEN=
# FREELANCEHUNT_PROXY_URL=

# Site pipeline O34: filter→Neon→parallel L1 (без очереди drain на новых)
# L1_MAX_WORKERS=4
# OPENROUTER_API_KEY_L1_B=sk-or-...  # только L1 воркеры 2/4; L2/judge — основной ключ
# L1_BACKLOG_DRAIN=1   # Site: пачка L1 для строк без verdict (свежие id первые)
# RADAR_CONVEYOR=1
# POLL_INTERVAL_MINUTES=1
# L1_BATCH_PER_CYCLE=40
# Биржи: sticky cascade (Proxy_1 → Proxy_2 → …), смена только при бане. Не TG_PROXY.
# EXCHANGE_PROXY_URLS=http://185.x:8000:user:pass,http://194.x:8000:user:pass,...
# (порядок = приоритет; 403/429 → сразу следующий; timeout → после 3 подряд; пуш в TG)
# EXCHANGE_PROXY_CONNECT_TIMEOUT_SEC=5
# EXCHANGE_PROXY_READ_TIMEOUT_SEC=20
# EXCHANGE_PROXY_STRIKES=3
# EXCHANGE_PROXY_BAN_TTL_SEC=3600
# EXCHANGE_PROXY_ALERT_COOLDOWN_SEC=600
# EXCHANGE_PROXY_LOW_POOL_COOLDOWN_SEC=300
# Совместимость: если EXCHANGE_* пусто — FL_PROXY_URLS
# FL_PROXY_URLS=http://212.102.151.153:8000:user:pass,http://185.147.131.15:8000:user:pass,...
# KWORK_PROXY_URLS=... (пусто → тот же каскад что FL/EXCHANGE)

# O91 ingest watchdog (VPS timer rawlead-ingest-watchdog)
# WATCHDOG_CYCLE_GAP_MIN=15
# WATCHDOG_INSERT_GAP_MIN=20
# WATCHDOG_L1_BACKLOG=120
# WATCHDOG_RESTART_GAP_MIN=25
# WATCHDOG_AUTO_RESTART=1
# WATCHDOG_ALERT_COOLDOWN_SEC=1800
# O108 — TZ из вложений на странице заказа (FL/Kwork): .docx/.pdf/.txt/.zip/.rar
# TZ_ATTACHMENTS_ENABLED=1
# TZ_ATTACHMENT_MAX_TEXT_MB=8
# TZ_ATTACHMENT_MAX_ARCHIVE_MB=2
# YOUDO_LISTING_URL=https://youdo.com/tasks-all-opened-all
# UI-категории на youdo.com НЕ попадают в URL; отсев — word_filter + L1
# YOUDO_PROXY_URLS=   # пусто → EXCHANGE_PROXY_URLS_SECONDARY (быстрые баны youdo:host)
# SECONDARY_FETCH_EVERY_N_CYCLES=2
# FREELANCE_RU_LISTING_URL=https://freelance.ru/project/search
# FREELANCE_RU_PROXY_URLS=
# FREELANCEJOB_LISTING_URL=https://www.freelancejob.ru/projects/
# FREELANCEJOB_LISTING_MAX_PAGES=1
# FREELANCEJOB_PROXY_URLS=
# PCHYOL_LISTING_URL=https://pchel.net/jobs/
# PCHYOL_LISTING_MAX_PAGES=1
# PCHYOL_MIN_PROJECT_ID=0
# PCHYOL_PROXY_URLS=

# --- База лидов (Neon Postgres вместо Supabase). Пусто = только SQLite на ПК ---
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# MATCH_PUSH (3f-A4): push match в TG после L1 visible lead (Site VPS)
# MATCH_PUSH=1

# Telegram Stars (3f-C): оплата подписки через @rawlead_bot
# STARS_ENABLED=1
# STARS_PRICE_XTR=300
# STARS_SUBSCRIPTION_DAYS=30

# P5-PREP / VPS: CORS — список origin через запятую (без *). Пусто = * (localhost)
# Локально: RADAR_CORS_ORIGINS=http://radarzakaz.local
# Прод VPS: RADAR_CORS_ORIGINS=https://rawlead.ru
# RADAR_CORS_ORIGINS=https://rawlead.ru
# API на VPS слушает :8000 (nginx → https://api.rawlead.ru). Локально — :18766.
# RAWLEAD_API_PORT=8000
# Логи воркеров main/tg: data/radar_site_exchanges.log, data/radar_site_tg.log (ротация ~5MB)

# Owner UUID для MVP single-user (O59b). См. users seed в Neon.
# RAWLEAD_OWNER_USER_ID=00000000-0000-0000-0000-000000000001
# Секрет для /ops/ (404 без ?key=). Сохрани закладку с ключом.
# RAWLEAD_OPS_KEY=

# O37b Playwright: JWT paid test user (только локально, не в git). См. docs/ops/PREPROD_ACCOUNTS.md
# RAWLEAD_PREPROD_ACCESS_TOKEN=
# O37b CDP: Dolphin Anty / браузер с remote debugging (окно уже открыто)
# DOLPHIN_CDP_URL=http://127.0.0.1:9222

# --- WordPress Local (только учёба / фаза 3). См. docs/ops/WP_CURSOR_CONNECT.md ---
# WP_LOCAL_SITE_URL=http://fl-radar-demo.local
# WP_APP_USER=admin
# WP_APP_PASSWORD=
